{
  "name": "pukeko-robot-controller",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev -w packages/web-client",
    "dev:ag-ui": "AGUI_URL=http://localhost:3000/agents/default/run npm run dev -w packages/web-client",
    "server": "npx gaunt-sloth-api ag-ui --port 3000 --config .gsloth.config.json",
    "stub": "npm run start -w packages/robot-stub",
    "test": "vitest run",
    "build": "npm run build -w packages/web-client"
  },
  "dependencies": {
    "@gaunt-sloth/api": "^0.0.2",
    "express": "^5.2.1",
    "vue": "^3.5.13",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "7.1.11",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.2.12"
  },
  "workspaces": [
    "packages/web-client",
    "packages/robot-stub"
  ]
}
