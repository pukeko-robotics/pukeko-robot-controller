{
  "name": "pukeko-robot-controller",
  "version": "0.0.2",
  "private": true,
  "description": "AI-driven control of an Acebott biped robot via the Pukeko web UI and @gaunt-sloth/api backend.",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ag-ui": "AGUI_URL=http://localhost:3000/agents/default/run vite",
    "server": "node --import=tsx ./server/index.ts",
    "stub": "node --import=tsx robot-stub/index.ts",
    "start": "concurrently -n server,client -c blue,green --kill-others-on-fail \"npm:server\" \"npm:dev\"",
    "test": "vitest run",
    "build": "vue-tsc --build && vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@galvanized-pukeko/vue-ui": "^0.0.11",
    "@gaunt-sloth/api": "^0.1.4",
    "@gaunt-sloth/core": "^0.1.4",
    "@langchain/anthropic": "^1.3.27",
    "@langchain/core": "^1.1.39",
    "@langchain/ollama": "1.2.6",
    "chart.js": "^4.5.1",
    "express": "^5.2.1",
    "langchain": "^1.3.1",
    "vue": "^3.5.13",
    "zod": "^3.25.76"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.2.12"
  }
}
